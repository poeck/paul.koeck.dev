---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base
  title="Projects | Simon Koeck"
  description="Open source projects and tools by Simon Koeck."
>
  <h1
    class="text-3xl sm:text-4xl font-medium tracking-tight text-zinc-50 mb-4"
  >
    Projects
  </h1>
  <p class="text-zinc-400 mb-14">Things I'm building.</p>

  <div class="grid gap-6">
    {
      projects.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="group relative block rounded-xl border border-zinc-800/60 overflow-hidden hover:border-zinc-700/60 transition-all hover:shadow-lg hover:shadow-black/20"
        >
          {project.data.hero && (
            <div class="relative aspect-video overflow-hidden">
              <img
                src={project.data.hero}
                alt={`Screenshot of ${project.data.name}`}
                width="1280"
                height="720"
                decoding="async"
                loading="lazy"
                class="w-full h-full object-cover object-top opacity-90 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-300"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 from-5% via-zinc-950/30 via-40% to-transparent" />
            </div>
          )}
          <div class="relative px-5 pb-6 -mt-14">
            <div class="flex items-baseline gap-3 mb-2">
              <h2 class="font-medium text-zinc-100 group-hover:text-white transition-colors text-xl">
                {project.data.name}
              </h2>
              <span class="text-sm font-mono text-zinc-600">
                {new URL(project.data.url).hostname}
              </span>
            </div>
            <p class="text-sm text-zinc-500 leading-relaxed">
              {project.data.description}
            </p>
          </div>
        </a>
      ))
    }
  </div>
</Base>
