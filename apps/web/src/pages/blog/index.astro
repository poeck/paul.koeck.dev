---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => p.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Blog | Simon Koeck"
  description="Blog posts about security, development, and technology by Simon Koeck."
>
  <h1
    class="text-3xl sm:text-4xl font-medium tracking-tight text-zinc-50 mb-2"
  >
    Blog
  </h1>
  <p class="text-zinc-400 mb-14">
    Posts about security, development, and technology.
  </p>

  {
    posts.length === 0 ? (
      <p class="text-zinc-600">No posts yet.</p>
    ) : (
      <div class="space-y-1">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block py-4 -mx-3 px-3 rounded-lg hover:bg-zinc-900/40 transition-colors"
          >
            <div class="flex items-center gap-2.5 mb-1.5 text-sm">
              <time
                class="text-zinc-500 font-mono text-xs"
                datetime={post.data.date.toISOString()}
              >
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              {post.data.tags.length > 0 && (
                <>
                  <span class="text-zinc-600">/</span>
                  <span class="text-zinc-500">{post.data.tags.join(", ")}</span>
                </>
              )}
            </div>
            <h2 class="font-medium text-zinc-200 group-hover:text-zinc-50 transition-colors text-base">
              {post.data.title}
            </h2>
            <p class="text-sm text-zinc-500 mt-1 leading-relaxed">
              {post.data.summary}
            </p>
          </a>
        ))}
      </div>
    )
  }
</Base>
