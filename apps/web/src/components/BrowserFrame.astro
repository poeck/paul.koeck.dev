---
interface Props {
  url?: string;
  class?: string;
}

const { url, class: className } = Astro.props;
---

<div class:list={["not-prose rounded-lg border border-zinc-800/60 overflow-hidden bg-zinc-900 my-6", className]}>
  <div class="flex items-center gap-2 px-3 py-2 border-b border-zinc-800/60 bg-zinc-900/80">
    <div class="flex gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full bg-red-500/70" />
      <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70" />
      <div class="w-2.5 h-2.5 rounded-full bg-green-500/70" />
    </div>
    {url && (
      <div class="flex-1 mx-2">
        <div class="bg-zinc-800/80 rounded-md px-3 py-1 text-[11px] font-mono text-zinc-500 truncate text-center max-w-xs mx-auto">
          {url}
        </div>
      </div>
    )}
  </div>
  <slot />
</div>
