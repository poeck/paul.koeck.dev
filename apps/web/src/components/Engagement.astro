---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
const reactions = [
  { emoji: "🔥", label: "Fire" },
  { emoji: "👀", label: "Interesting" },
  { emoji: "💡", label: "Insightful" },
  { emoji: "🎯", label: "Accurate" },
];
---

<div id="engagement" class="mt-10 pt-6 border-t border-zinc-800/60" data-slug={slug}>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-1.5 text-sm text-zinc-400">
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
        ></path>
        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <span id="view-count" class="tabular-nums text-zinc-400">--</span>
    </div>
    <div class="flex items-center gap-4">
      {
        reactions.map(({ emoji, label }) => (
          <button
            data-emoji={emoji}
            aria-label={label}
            class="reaction-btn flex flex-col items-center gap-1.5 cursor-pointer group"
          >
            <span class="reaction-emoji text-xl leading-none transition-transform duration-150 group-hover:scale-125">
              {emoji}
            </span>
            <span class="reaction-count tabular-nums text-sm text-zinc-500 font-medium font-mono">
              0
            </span>
          </button>
        ))
      }
    </div>
  </div>
</div>

<style>
  .reaction-btn {
    background: none;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .reaction-btn .reaction-emoji {
    filter: saturate(0.3) brightness(0.7);
    transition:
      filter 0.2s ease,
      transform 0.15s ease;
  }
  .reaction-btn:hover .reaction-emoji,
  .reaction-btn.reacted .reaction-emoji {
    filter: saturate(1) brightness(1);
  }
  .reaction-btn.reacted .reaction-emoji {
    filter: saturate(1) brightness(1) drop-shadow(0 0 6px rgba(255 255 255 / 0.2));
  }
  .reaction-btn.reacted .reaction-count {
    color: rgb(161 161 170);
  }
</style>

<script>
  let cleanupController: AbortController | null = null;

  function initEngagement() {
    // Abort previous listeners from prior navigation
    if (cleanupController) cleanupController.abort();
    cleanupController = new AbortController();
    const { signal } = cleanupController;

    const container = document.getElementById("engagement");
    if (!container) return;

    const slug = container.dataset.slug;
    if (!slug) return;

    const viewCount = document.getElementById("view-count");
    const reactionBtns =
      container.querySelectorAll<HTMLButtonElement>(".reaction-btn");

    const storageKey = `reactions:${slug}`;
    let stored: Record<string, boolean> = {};
    try {
      stored = JSON.parse(localStorage.getItem(storageKey) || "{}");
    } catch {
      stored = {};
    }
    reactionBtns.forEach((btn) => {
      if (stored[btn.dataset.emoji!]) btn.classList.add("reacted");
    });

    const displayCounts: Record<string, number> = {};
    const unsent: Record<string, number> = {};
    let syncTimer: ReturnType<typeof setTimeout> | null = null;

    function render() {
      reactionBtns.forEach((btn) => {
        const emoji = btn.dataset.emoji!;
        const countEl = btn.querySelector(".reaction-count");
        if (countEl) countEl.textContent = (displayCounts[emoji] || 0).toString();
      });
    }

    function flush() {
      if (syncTimer) {
        clearTimeout(syncTimer);
        syncTimer = null;
      }

      const toSend: Record<string, number> = {};
      for (const [emoji, count] of Object.entries(unsent)) {
        if (count > 0) toSend[emoji] = count;
      }
      if (Object.keys(toSend).length === 0) return;

      for (const emoji of Object.keys(toSend)) {
        delete unsent[emoji];
      }

      fetch(`/api/reactions/${slug}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ reactions: toSend }),
        keepalive: true,
      }).catch(() => {
        for (const [emoji, count] of Object.entries(toSend)) {
          unsent[emoji] = (unsent[emoji] || 0) + count;
        }
      });
    }

    function scheduleSync() {
      if (syncTimer) return;
      syncTimer = setTimeout(flush, 2_000);
    }

    function spawnBurst(btn: HTMLButtonElement, emoji: string) {
      const emojiEl = btn.querySelector(".reaction-emoji") as HTMLElement;
      const rect = emojiEl.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      emojiEl.animate(
        [
          { transform: "scale(1)" },
          { transform: "scale(1.5)" },
          { transform: "scale(1)" },
        ],
        { duration: 400, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)" },
      );

      const count = 7;
      for (let i = 0; i < count; i++) {
        const p = document.createElement("span");
        p.textContent = emoji;
        p.style.cssText =
          "position:fixed;pointer-events:none;z-index:50;font-size:16px;";
        p.style.left = cx + "px";
        p.style.top = cy + "px";
        document.body.appendChild(p);

        const angle =
          (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.7;
        const dist = 40 + Math.random() * 35;
        const dx = Math.cos(angle) * dist;
        const dy = Math.sin(angle) * dist - 15;
        const rotation = (Math.random() - 0.5) * 120;

        const anim = p.animate(
          [
            {
              transform: "translate(-50%, -50%) scale(1) rotate(0deg)",
              opacity: 1,
            },
            {
              transform: `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px)) scale(0) rotate(${rotation}deg)`,
              opacity: 0,
            },
          ],
          {
            duration: 500 + Math.random() * 200,
            easing: "cubic-bezier(0.15, 0.8, 0.3, 1)",
            fill: "forwards",
          },
        );
        anim.onfinish = () => p.remove();
      }
    }

    // Fetch initial counts (only time we read from the API)
    fetch(`/api/reactions/${slug}`)
      .then((r) => r.json())
      .then((data) => {
        const initial = data.reactions || {};
        for (const [emoji, count] of Object.entries(initial)) {
          displayCounts[emoji] = (count as number) + (displayCounts[emoji] || 0);
        }
        render();
      })
      .catch(() => {});

    fetch(`/api/views/${slug}`, { method: "POST" })
      .then((r) => r.json())
      .then((data) => {
        if (viewCount) viewCount.textContent = data.views.toString();
      })
      .catch(() => {});

    // Click handlers (cleaned up automatically when DOM swaps)
    reactionBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const emoji = btn.dataset.emoji;
        if (!emoji) return;

        spawnBurst(btn, emoji);
        displayCounts[emoji] = (displayCounts[emoji] || 0) + 1;
        unsent[emoji] = (unsent[emoji] || 0) + 1;
        render();
        scheduleSync();

        stored[emoji] = true;
        localStorage.setItem(storageKey, JSON.stringify(stored));
        btn.classList.add("reacted");
      });
    });

    // Flush on page leave / navigation (cleaned up via AbortController)
    document.addEventListener(
      "visibilitychange",
      () => {
        if (document.visibilityState === "hidden") flush();
      },
      { signal },
    );
  }

  initEngagement();
</script>
