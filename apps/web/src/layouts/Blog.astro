---
import Base from "./Base.astro";
import ProgressBar from "../components/ProgressBar.astro";
import Engagement from "../components/Engagement.astro";
import type { CollectionEntry } from "astro:content";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<"blog">;
  prev?: CollectionEntry<"blog"> | null;
  next?: CollectionEntry<"blog"> | null;
  readingTime?: number;
  headings?: Heading[];
}

const { entry, prev, next, readingTime, headings = [] } = Astro.props;
const { title, date, tags, summary } = entry.data;

const slug = entry.id;
const ogImage = new URL(`/og/blog/${slug}.png`, Astro.site).href;
const pageUrl = new URL(`/blog/${slug}`, Astro.site).href;

const pageTitle = title + " | Paul Koeck";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: summary,
  datePublished: date.toISOString(),
  image: ogImage,
  wordCount: readingTime ? readingTime * 230 : undefined,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  author: {
    "@type": "Person",
    name: "Paul Koeck",
    url: "https://paul.koeck.dev",
  },
  publisher: {
    "@type": "Person",
    name: "Paul Koeck",
    url: "https://paul.koeck.dev",
  },
  keywords: tags.join(", "),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://paul.koeck.dev" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://paul.koeck.dev/blog" },
    { "@type": "ListItem", position: 3, name: title, item: pageUrl },
  ],
};
---

<Base
  title={pageTitle}
  description={summary}
  og={{
    type: "article",
    image: ogImage,
    article: {
      publishedTime: date.toISOString(),
      tags,
    },
  }}
>
  <ProgressBar />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <article data-pagefind-body>
    <header class="mb-14">
      <div class="flex items-center gap-2.5 text-sm mb-5">
        <time class="text-zinc-400" datetime={date.toISOString()}>
          {
            date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </time>
        {
          readingTime && (
            <>
              <span class="text-zinc-600">/</span>
              <span class="text-zinc-500">{readingTime} min read</span>
            </>
          )
        }
      </div>
      <h1
        class="text-3xl sm:text-4xl font-medium tracking-tight text-zinc-50 leading-tight mb-4"
      >
        {title}
      </h1>
      <p class="text-zinc-400 leading-relaxed">{summary}</p>
    </header>

    <div
      class="prose prose-invert prose-base max-w-none prose-headings:tracking-tight prose-code:before:content-none prose-code:after:content-none"
    >
      <slot />
    </div>
    <Engagement slug={`blog/${slug}`} />
    {
      (prev || next) && (
        <nav class="mt-6 pt-4 border-t border-zinc-800/60 grid grid-cols-2 gap-8">
          {prev ? (
            <a
              href={`/blog/${prev.id}`}
              class="group flex flex-col gap-1"
            >
              <span class="text-xs text-zinc-500 group-hover:text-zinc-300 transition-colors">
                &larr; Previous
              </span>
              <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors">
                {prev.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {next ? (
            <a
              href={`/blog/${next.id}`}
              class="group flex flex-col gap-1 items-end text-right"
            >
              <span class="text-xs text-zinc-500 group-hover:text-zinc-300 transition-colors">
                Next &rarr;
              </span>
              <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors">
                {next.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      )
    }
  </article>
  <script>
    function initAnchorLinks() {
      document.querySelectorAll(".prose h2[id], .prose h3[id]").forEach((h) => {
        if (h.querySelector("a[href^='#']")) return;
        h.style.cursor = "pointer";
        h.addEventListener("click", () => {
          const id = h.getAttribute("id");
          if (!id) return;
          history.replaceState(null, "", `#${id}`);
          h.scrollIntoView({ behavior: "smooth" });
        });
      });
    }

    initAnchorLinks();
  </script>
</Base>
