---
import "../styles/global.css";
import CopyButton from "../components/CopyButton.astro";
import CommandPalette from "../components/CommandPalette.astro";
import VimKeys from "../components/VimKeys.astro";

interface Props {
  title: string;
  description?: string;
  robots?: string;
  og?: {
    type?: string;
    image?: string;
    article?: {
      publishedTime?: string;
      tags?: string[];
    };
  };
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = "Paul Koeck — Full-stack developer and security researcher",
  robots: robotsProp,
  og,
} = Astro.props;

const ogType = og?.type ?? "website";
const ogImage = og?.image ?? new URL("/og.png", Astro.site).href;

const pathname = Astro.url.pathname;

const noIndexPaths = ["/imprint", "/privacy", "/404"];
const robots =
  robotsProp ?? (noIndexPaths.includes(pathname) ? "noindex, follow" : "index, follow");
---

<!doctype html>
<html lang="en" style="background:#09090b;color-scheme:dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="author" content="Paul Koeck" />
    <meta name="robots" content={robots} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Paul Koeck"
      href="/rss.xml"
    />
    <meta name="theme-color" content="#09090b" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Paul Koeck" />
    <meta property="og:locale" content="en_US" />
    {
      og?.article?.publishedTime && (
        <meta
          property="article:published_time"
          content={og.article.publishedTime}
        />
      )
    }
    {
      og?.article?.tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-zinc-950 text-zinc-300 min-h-screen font-sans" data-pagefind-ignore>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-zinc-800 focus:text-zinc-100 focus:rounded-md focus:text-sm">
      Skip to content
    </a>
    <header class="max-w-2xl mx-auto px-6 pt-10 pb-2">
      <nav class="flex items-center justify-between" aria-label="Main navigation">
        <a
          href="/"
          class="text-zinc-50 font-mono text-sm tracking-tight"
        >
          <span class="text-zinc-600">~$</span> paulkoeck
        </a>
        <div class="flex items-center gap-5 text-sm text-zinc-400">
          <a
            href="/writeups"
            class:list={[
              "transition-colors",
              pathname.startsWith("/writeups")
                ? "text-zinc-200"
                : "hover:text-zinc-300",
            ]}
          >
            Writeups
          </a>
          <a
            href="/projects"
            class:list={[
              "transition-colors",
              pathname.startsWith("/projects")
                ? "text-zinc-200"
                : "hover:text-zinc-300",
            ]}
          >
            Projects
          </a>
          <a
            href="/about"
            class:list={[
              "transition-colors",
              pathname.startsWith("/about")
                ? "text-zinc-200"
                : "hover:text-zinc-300",
            ]}
          >
            About
          </a>
          <button
            id="cp-trigger"
            class="flex items-center gap-1.5 hover:text-zinc-300 transition-colors"
            aria-label="Search"
          >
            <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z" />
            </svg>
            <kbd class="hidden sm:inline text-[11px] font-mono border border-zinc-800 rounded px-1.5 py-0.5 text-zinc-500"
              >&#8984;K</kbd
            >
          </button>
        </div>
      </nav>
    </header>
    <main id="main-content" class="max-w-2xl mx-auto px-6 pt-16 pb-24">
      <slot />
    </main>
    <footer class="max-w-2xl mx-auto px-6 pb-10 flex items-center justify-between text-xs text-zinc-400">
      <span>&copy; {new Date().getFullYear()} Paul Koeck. All rights reserved.</span>
      <div class="flex gap-4">
        <a href="/imprint" class="hover:text-zinc-400 transition-colors">Imprint</a>
        <a href="/privacy" class="hover:text-zinc-400 transition-colors">Privacy</a>
      </div>
    </footer>
    <CopyButton />
    <CommandPalette />
    <VimKeys />

  </body>
</html>
