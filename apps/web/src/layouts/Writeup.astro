---
import Base from "./Base.astro";
import ProgressBar from "../components/ProgressBar.astro";
import Engagement from "../components/Engagement.astro";
import type { CollectionEntry } from "astro:content";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<"writeups">;
  prev?: CollectionEntry<"writeups"> | null;
  next?: CollectionEntry<"writeups"> | null;
  readingTime?: number;
  headings?: Heading[];
}

const { entry, prev, next, readingTime, headings = [] } = Astro.props;
const { title, date, severity, platform, tags, summary, cve, ghsa, ghsaUrl, cvss } =
  entry.data;
const ghsaHref = ghsaUrl ?? (ghsa ? `https://github.com/advisories/${ghsa}` : undefined);

const severityColors: Record<string, string> = {
  critical: "text-severity-critical",
  high: "text-severity-high",
  medium: "text-severity-medium",
  low: "text-severity-low",
  info: "text-severity-info",
};

function cvssColor(score: number): string {
  if (score >= 9.0) return "#ef4444";
  if (score >= 7.0) return "#f97316";
  if (score >= 4.0) return "#eab308";
  if (score >= 0.1) return "#3b82f6";
  return "#71717a";
}

function cvssLabel(score: number): string {
  if (score >= 9.0) return "Critical";
  if (score >= 7.0) return "High";
  if (score >= 4.0) return "Medium";
  if (score >= 0.1) return "Low";
  return "None";
}

const slug = entry.id;
const ogImage = new URL(`/og/${slug}.png`, Astro.site).href;
const pageUrl = new URL(`/writeups/${slug}`, Astro.site).href;

const pageTitle = [cve, title].filter(Boolean).join(": ") + " | Simon Koeck";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: summary,
  datePublished: date.toISOString(),
  image: ogImage,
  wordCount: readingTime ? readingTime * 230 : undefined,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  author: {
    "@type": "Person",
    name: "Simon Koeck",
    url: "https://simonkoeck.com",
  },
  publisher: {
    "@type": "Person",
    name: "Simon Koeck",
    url: "https://simonkoeck.com",
  },
  keywords: tags.join(", "),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://simonkoeck.com" },
    { "@type": "ListItem", position: 2, name: "Writeups", item: "https://simonkoeck.com/writeups" },
    { "@type": "ListItem", position: 3, name: title, item: pageUrl },
  ],
};
---

<Base
  title={pageTitle}
  description={summary}
  og={{
    type: "article",
    image: ogImage,
    article: {
      publishedTime: date.toISOString(),
      tags,
    },
  }}
>
  <ProgressBar />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <article data-pagefind-body>
    <header class="mb-14">
      <div class="flex items-center gap-2.5 text-sm mb-5">
        <span
          class:list={[
            "font-medium uppercase text-xs tracking-widest",
            severityColors[severity],
          ]}
        >
          {severity}
        </span>
        <span class="text-zinc-600">/</span>
        <span class="text-zinc-400">{platform}</span>
        <span class="text-zinc-600">/</span>
        <time class="text-zinc-400" datetime={date.toISOString()}>
          {
            date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </time>
        {
          readingTime && (
            <>
              <span class="text-zinc-600">/</span>
              <span class="text-zinc-500">{readingTime} min read</span>
            </>
          )
        }
      </div>
      <h1
        class="text-3xl sm:text-4xl font-medium tracking-tight text-zinc-50 leading-tight mb-4"
      >
        {title}
      </h1>
      <p class="text-zinc-400 leading-relaxed">{summary}</p>

      {/* CVSS + CVE/GHSA */}
      {
        (cvss != null || cve || ghsa) && (
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mt-6 text-sm font-mono text-zinc-500">
            {cvss != null && (
              <>
                <span>CVSS</span>
                <div class="flex items-center gap-0.5">
                  {Array.from({ length: 10 }, (_, i) => (
                    <div
                      class="w-1.5 h-4 rounded-sm"
                      style={`background: ${i < Math.round(cvss) ? cvssColor(cvss) : "rgb(39 39 42 / 0.5)"}`}
                    />
                  ))}
                </div>
                <span class="font-medium" style={`color: ${cvssColor(cvss)}`}>
                  {cvss.toFixed(1)}
                </span>
              </>
            )}
            {cvss != null && (cve || ghsa) && (
              <span class="text-zinc-700">|</span>
            )}
            {cve && (
              <a
                href={`https://nvd.nist.gov/vuln/detail/${cve}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-zinc-300 transition-colors"
              >
                {cve}
              </a>
            )}
            {ghsa && ghsaHref && (
              <a
                href={ghsaHref}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-zinc-300 transition-colors"
              >
                {ghsa}
              </a>
            )}
          </div>
        )
      }
    </header>

    <div
      class="prose prose-invert prose-base max-w-none prose-headings:tracking-tight prose-code:before:content-none prose-code:after:content-none"
    >
      <slot />
    </div>
    <Engagement slug={slug} />
    {
      (prev || next) && (
        <nav class="mt-6 pt-4 border-t border-zinc-800/60 grid grid-cols-2 gap-8">
          {prev ? (
            <a
              href={`/writeups/${prev.id}`}
              class="group flex flex-col gap-1"
            >
              <span class="text-xs text-zinc-500 group-hover:text-zinc-300 transition-colors">
                &larr; Previous
              </span>
              <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors">
                {prev.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {next ? (
            <a
              href={`/writeups/${next.id}`}
              class="group flex flex-col gap-1 items-end text-right"
            >
              <span class="text-xs text-zinc-500 group-hover:text-zinc-300 transition-colors">
                Next &rarr;
              </span>
              <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors">
                {next.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      )
    }
  </article>
  <script>
    function initAnchorLinks() {
      document.querySelectorAll(".prose h2[id], .prose h3[id]").forEach((h) => {
        if (h.querySelector("a[href^='#']")) return;
        h.style.cursor = "pointer";
        h.addEventListener("click", () => {
          const id = h.getAttribute("id");
          if (!id) return;
          history.replaceState(null, "", `#${id}`);
          h.scrollIntoView({ behavior: "smooth" });
        });
      });
    }

    function scrollToHash() {
      const hash = window.location.hash.slice(1);
      if (!hash) return;
      const target = document.getElementById(hash);
      if (target) target.scrollIntoView();
    }

    initAnchorLinks();
  </script>
</Base>
